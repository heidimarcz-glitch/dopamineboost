<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dopamine Boost · Sober Sidekick</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --purple:#a581ff; --periwinkle:#748eff; --sky:#00c4ff;
    --teal:#00c7ce; --green:#00c735; --ink:#303030;
    --light-blue:#cde2ff; --bg:#f6f7ff;
    --card:rgba(255,255,255,0.93); --muted:#7878a0;
    --border:rgba(165,129,255,0.16);
    --shadow:0 8px 32px rgba(116,142,255,0.12);
    --shadow-lg:0 20px 56px rgba(116,142,255,0.2);
    --grad-main:linear-gradient(135deg,#a581ff 0%,#748eff 50%,#00c4ff 100%);
    --grad-btn:linear-gradient(135deg,#a581ff 0%,#748eff 100%);
    --grad-rec:linear-gradient(135deg,#00c7ce 0%,#00c735 100%);
  }
  *{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'Poppins',sans-serif;background:var(--bg);color:var(--ink);min-height:100vh;overflow-x:hidden;}
  .bg{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none;}
  .orb{position:absolute;border-radius:50%;filter:blur(90px);opacity:.16;animation:drift 14s ease-in-out infinite alternate;}
  .orb-1{width:650px;height:650px;background:var(--purple);top:-220px;right:-120px;}
  .orb-2{width:520px;height:520px;background:var(--teal);bottom:-160px;left:-80px;animation-delay:-5s;}
  .orb-3{width:380px;height:380px;background:var(--sky);top:45%;left:35%;animation-delay:-9s;}
  @keyframes drift{from{transform:translate(0,0) scale(1);}to{transform:translate(28px,18px) scale(1.06);}}
  .app{position:relative;z-index:1;min-height:100vh;}

  header{text-align:center;padding:40px 24px 24px;}
  .ssk-wordmark{display:inline-flex;align-items:center;gap:10px;margin-bottom:20px;animation:fadeDown .6s ease both;}
  .ssk-name{font-size:.95rem;font-weight:700;color:var(--ink);text-align:left;line-height:1.25;}
  .ssk-name span{display:block;font-weight:500;font-size:.72rem;color:var(--muted);}
  .page-title{font-size:clamp(1.85rem,5vw,3rem);font-weight:800;line-height:1.15;color:var(--ink);animation:fadeDown .6s .08s ease both;opacity:0;}
  .grad{background:var(--grad-main);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;}
  .tagline{margin-top:9px;font-size:.97rem;font-weight:500;color:var(--muted);animation:fadeDown .6s .16s ease both;opacity:0;}
  @keyframes fadeDown{from{opacity:0;transform:translateY(-16px);}to{opacity:1;transform:none;}}

  .saved-btn-wrap{margin-top:14px;animation:fadeDown .6s .22s ease both;opacity:0;}
  .btn-saved-header{font-family:'Poppins',sans-serif;font-size:.78rem;font-weight:700;border:2px solid rgba(116,142,255,.3);border-radius:99px;padding:8px 18px;background:rgba(255,255,255,.7);color:var(--periwinkle);cursor:pointer;transition:all .2s;backdrop-filter:blur(6px);}
  .btn-saved-header:hover{background:var(--grad-btn);color:white;border-color:transparent;}

  .progress-wrap{max-width:520px;margin:0 auto 28px;padding:0 24px;animation:fadeDown .6s .2s ease both;opacity:0;}
  .progress-label{display:flex;justify-content:space-between;font-size:.71rem;font-weight:600;color:var(--muted);margin-bottom:7px;}
  .progress-track{height:7px;background:var(--light-blue);border-radius:99px;overflow:hidden;}
  .progress-fill{height:100%;background:var(--grad-btn);border-radius:99px;transition:width .5s cubic-bezier(.4,0,.2,1);width:0%;}

  .quiz-container{max-width:560px;margin:0 auto;padding:0 20px 80px;}
  .question-card{background:var(--card);border-radius:28px;padding:38px 34px;box-shadow:var(--shadow-lg);backdrop-filter:blur(14px);border:1.5px solid rgba(255,255,255,.88);animation:slideUp .45s cubic-bezier(.4,0,.2,1) both;}
  @keyframes slideUp{from{opacity:0;transform:translateY(28px);}to{opacity:1;transform:none;}}
  .q-label{font-size:.67rem;font-weight:700;text-transform:uppercase;letter-spacing:2.5px;color:var(--purple);margin-bottom:8px;}
  .q-text{font-size:1.2rem;font-weight:700;color:var(--ink);line-height:1.45;margin-bottom:24px;}
  .options{display:grid;gap:10px;}
  .option-btn{display:flex;align-items:center;gap:13px;background:rgba(255,255,255,.55);border:2px solid var(--border);border-radius:15px;padding:14px 17px;cursor:pointer;font-family:'Poppins',sans-serif;font-size:.89rem;font-weight:600;color:var(--ink);transition:all .2s ease;text-align:left;}
  .option-btn:hover{border-color:var(--periwinkle);background:rgba(116,142,255,.07);transform:translateY(-2px);box-shadow:0 6px 20px rgba(116,142,255,.14);}
  .option-btn.selected{border-color:var(--purple);background:linear-gradient(135deg,rgba(165,129,255,.1),rgba(116,142,255,.07));box-shadow:0 6px 24px rgba(165,129,255,.2);}
  .option-emoji{font-size:1.35rem;flex-shrink:0;}
  .option-text{flex:1;}
  .option-sub{font-size:.74rem;font-weight:500;color:var(--muted);margin-top:2px;}
  .multi-hint{font-size:.72rem;font-weight:600;color:var(--muted);margin-bottom:12px;display:flex;align-items:center;gap:5px;}

  .nav-row{display:flex;justify-content:space-between;align-items:center;margin-top:26px;}
  .btn{font-family:'Poppins',sans-serif;font-size:.9rem;font-weight:700;border:none;border-radius:99px;padding:13px 28px;cursor:pointer;transition:all .2s ease;letter-spacing:.2px;}
  .btn-primary{background:var(--grad-btn);color:white;box-shadow:0 6px 24px rgba(165,129,255,.38);}
  .btn-primary:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(165,129,255,.48);}
  .btn-primary:disabled{opacity:.35;cursor:not-allowed;transform:none;box-shadow:none;}
  .btn-ghost{background:transparent;color:var(--muted);border:2px solid rgba(116,142,255,.2);}
  .btn-ghost:hover{background:rgba(116,142,255,.06);}
  .btn-save{background:var(--grad-rec);color:white;box-shadow:0 6px 24px rgba(0,199,206,.35);}
  .btn-save:hover{transform:translateY(-2px);box-shadow:0 10px 32px rgba(0,199,206,.45);}
  .btn-save:disabled{opacity:.4;cursor:not-allowed;transform:none;box-shadow:none;}
  .btn-outline{background:transparent;color:var(--periwinkle);border:2px solid rgba(116,142,255,.35);}
  .btn-outline:hover{background:rgba(116,142,255,.07);border-color:var(--periwinkle);}

  #loading-screen{display:none;text-align:center;padding:80px 24px;max-width:480px;margin:0 auto;}
  .loading-visual{margin:0 auto 30px;width:110px;height:110px;position:relative;}
  .loading-ring{position:absolute;inset:0;border-radius:50%;border:4px solid transparent;animation:spin 1.4s linear infinite;}
  .ring-1{border-top-color:var(--purple);}
  .ring-2{inset:12px;border-top-color:var(--sky);animation-duration:1s;animation-direction:reverse;}
  .ring-3{inset:24px;border-top-color:var(--teal);animation-duration:.8s;}
  @keyframes spin{to{transform:rotate(360deg);}}
  .loading-icon{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:1.8rem;}
  .loading-title{font-size:1.45rem;font-weight:700;color:var(--ink);margin-bottom:10px;}
  .loading-msg{font-size:.9rem;font-weight:500;color:var(--muted);animation:pulse 2s ease-in-out infinite;}
  @keyframes pulse{0%,100%{opacity:.5}50%{opacity:1}}

  #results-screen{display:none;max-width:700px;margin:0 auto;padding:0 20px 100px;}
  .results-header{text-align:center;margin-bottom:32px;animation:fadeDown .6s ease both;}
  .results-title{font-size:clamp(1.55rem,4.5vw,2.5rem);font-weight:800;color:var(--ink);margin-bottom:8px;line-height:1.2;}
  .results-sub{font-size:.92rem;font-weight:500;color:var(--muted);}
  .mood-pill{display:inline-block;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:white;background:var(--grad-btn);border-radius:99px;padding:5px 16px;margin-bottom:13px;}
  .rec-banner{display:none;align-items:center;justify-content:center;gap:8px;background:linear-gradient(135deg,rgba(0,199,206,.1),rgba(0,199,53,.06));border:1.5px solid rgba(0,199,206,.28);border-radius:99px;padding:10px 22px;margin-bottom:28px;font-size:.78rem;font-weight:700;color:#008a7a;}

  .playlist-grid{display:grid;gap:16px;}
  .playlist-item{background:var(--card);border-radius:22px;padding:24px;box-shadow:var(--shadow);border:1.5px solid rgba(255,255,255,.9);display:flex;gap:17px;align-items:flex-start;animation:slideUp .5s ease both;transition:transform .2s,box-shadow .2s;backdrop-filter:blur(10px);}
  .playlist-item:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg);}
  .playlist-item.recovery-item{border-color:rgba(0,199,206,.3);background:linear-gradient(135deg,rgba(0,199,206,.06),rgba(0,199,53,.04),rgba(255,255,255,.93));box-shadow:0 8px 32px rgba(0,199,206,.11);}
  .playlist-item.recovery-item:hover{box-shadow:0 20px 56px rgba(0,199,206,.2);}
  .item-number{width:36px;height:36px;flex-shrink:0;border-radius:11px;background:var(--grad-btn);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:.86rem;color:white;}
  .recovery-item .item-number{background:var(--grad-rec);}
  .item-body{flex:1;min-width:0;}
  .recovery-tag{display:inline-flex;align-items:center;gap:4px;font-size:.63rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:#007a70;margin-bottom:4px;}
  .item-type-badge{display:inline-flex;align-items:center;gap:3px;font-size:.64rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;padding:3px 9px;border-radius:99px;margin-bottom:7px;}
  .badge-song{background:rgba(0,196,255,.12);color:#006b96;}
  .badge-read{background:rgba(116,142,255,.12);color:#3f52c0;}
  .badge-video{background:rgba(165,129,255,.14);color:#5f2ecc;}
  .badge-activity{background:rgba(0,199,53,.11);color:#006d1a;}
  .badge-quote{background:rgba(116,142,255,.12);color:#3f52c0;}
  .badge-podcast{background:rgba(0,199,206,.12);color:#006b70;}
  .badge-fact{background:rgba(0,126,255,.1);color:#0050b8;}
  .item-title{font-size:.97rem;font-weight:700;color:var(--ink);margin-bottom:5px;line-height:1.35;}
  .item-desc{font-size:.82rem;font-weight:500;color:var(--muted);line-height:1.62;}
  .item-link{display:inline-flex;align-items:center;gap:5px;margin-top:11px;font-size:.76rem;font-weight:700;color:var(--periwinkle);text-decoration:none;border:1.5px solid rgba(116,142,255,.28);border-radius:99px;padding:5px 13px;transition:all .2s;}
  .item-link:hover{background:var(--periwinkle);color:white;border-color:var(--periwinkle);}
  .recovery-item .item-link{color:#007a70;border-color:rgba(0,199,206,.32);}
  .recovery-item .item-link:hover{background:var(--teal);color:white;border-color:var(--teal);}
  .item-emoji{font-size:1.75rem;flex-shrink:0;}

  .action-row{display:flex;flex-wrap:wrap;justify-content:center;gap:12px;margin-top:36px;animation:fadeDown .6s .3s ease both;opacity:0;}

  #saved-screen{display:none;max-width:700px;margin:0 auto;padding:0 20px 100px;}
  .saved-header{text-align:center;margin-bottom:32px;animation:fadeDown .55s ease both;}
  .saved-title{font-size:clamp(1.5rem,4vw,2.2rem);font-weight:800;color:var(--ink);margin-bottom:8px;}
  .saved-sub{font-size:.9rem;font-weight:500;color:var(--muted);}
  .saved-grid{display:grid;gap:16px;}
  .saved-card{background:var(--card);border-radius:20px;padding:22px 24px;border:1.5px solid rgba(255,255,255,.9);box-shadow:var(--shadow);display:flex;align-items:center;gap:18px;animation:slideUp .4s ease both;transition:transform .2s,box-shadow .2s;}
  .saved-card:hover{transform:translateY(-3px);box-shadow:var(--shadow-lg);}
  .saved-card-icon{width:52px;height:52px;border-radius:16px;background:var(--grad-btn);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:1.4rem;}
  .saved-card-body{flex:1;min-width:0;}
  .saved-card-label{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--purple);margin-bottom:3px;}
  .saved-card-title{font-size:1rem;font-weight:700;color:var(--ink);margin-bottom:4px;}
  .saved-card-meta{font-size:.77rem;font-weight:500;color:var(--muted);}
  .saved-card-actions{display:flex;gap:8px;flex-shrink:0;}
  .btn-xs{font-family:'Poppins',sans-serif;font-size:.74rem;font-weight:700;border-radius:99px;padding:7px 14px;border:none;cursor:pointer;transition:all .2s;}
  .btn-xs-primary{background:var(--grad-btn);color:white;}
  .btn-xs-primary:hover{transform:translateY(-1px);box-shadow:0 4px 14px rgba(165,129,255,.4);}
  .btn-xs-danger{background:rgba(255,80,100,.1);color:#cc2244;border:1.5px solid rgba(255,80,100,.2);}
  .btn-xs-danger:hover{background:rgba(255,80,100,.18);}
  .saved-empty{text-align:center;padding:60px 20px;font-size:.95rem;font-weight:500;color:var(--muted);}
  .saved-empty-icon{font-size:2.8rem;margin-bottom:14px;}
  .saved-back{text-align:center;margin-top:32px;}

  #toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(80px);background:#1e1e3a;color:white;font-size:.84rem;font-weight:600;padding:12px 22px;border-radius:99px;box-shadow:0 8px 32px rgba(0,0,0,.2);transition:transform .35s cubic-bezier(.4,0,.2,1),opacity .35s;opacity:0;z-index:999;white-space:nowrap;}
  #toast.show{transform:translateX(-50%) translateY(0);opacity:1;}
</style>
</head>
<body>
<div class="bg">
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
</div>
<div class="app">
  <header>
    <div class="ssk-wordmark">
      <svg width="42" height="42" viewBox="0 0 42 42" fill="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <linearGradient id="g1" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#a581ff"/><stop offset="100%" stop-color="#748eff"/></linearGradient>
          <linearGradient id="g2" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#00c7ce"/><stop offset="100%" stop-color="#00c4ff"/></linearGradient>
          <radialGradient id="cg" cx="50%" cy="50%" r="50%"><stop offset="0%" stop-color="#dfcfee"/><stop offset="100%" stop-color="#cde2ff"/></radialGradient>
        </defs>
        <polygon points="7,36 21,10 35,36" fill="url(#g1)" opacity="0.88"/>
        <polygon points="17,36 26,19 35,36" fill="url(#g2)" opacity="0.95"/>
        <circle cx="15" cy="32" r="7" fill="url(#cg)"/>
        <text x="15" y="35.5" text-anchor="middle" font-family="Poppins,sans-serif" font-size="7" font-weight="800" fill="#748eff">1</text>
      </svg>
      <div class="ssk-name">Sober Sidekick <span>Recovery Support Community</span></div>
    </div>
    <div class="page-title">Your <span class="grad">Dopamine Boost</span> 🌟</div>
    <div class="tagline">A personalized feel-good playlist, crafted just for you</div>
    <div class="saved-btn-wrap" id="saved-btn-wrap" style="display:none">
      <button class="btn-saved-header" onclick="showSaved()">📚 My Saved Playlists</button>
    </div>
  </header>

  <div id="quiz-screen">
    <div class="progress-wrap">
      <div class="progress-label"><span id="step-label">Step 1 of 7</span><span id="pct-label">0%</span></div>
      <div class="progress-track"><div class="progress-fill" id="progress-fill"></div></div>
    </div>
    <div class="quiz-container"><div class="question-card" id="question-card"></div></div>
  </div>

  <div id="loading-screen">
    <div class="loading-visual">
      <div class="loading-ring ring-1"></div>
      <div class="loading-ring ring-2"></div>
      <div class="loading-ring ring-3"></div>
      <div class="loading-icon">✨</div>
    </div>
    <div class="loading-title">Building Your Boost</div>
    <div class="loading-msg" id="loading-msg">Curating your feel-good collection…</div>
  </div>

  <div id="results-screen">
    <div class="results-header">
      <div class="results-title">Your Feel-Good Playlist 🎉</div>
      <div class="results-sub" id="results-intro">Hand-curated just for your vibe.</div>
    </div>
    <div class="rec-banner" id="rec-banner"><span>💚</span><span id="rec-banner-text"></span></div>
    <div class="playlist-grid" id="playlist-grid"></div>
    <div class="action-row">
      <button class="btn btn-save" id="save-btn" onclick="savePlaylist()">💾 Save This Playlist</button>
      <button class="btn btn-outline" onclick="restart()">✨ New Playlist</button>
    </div>
  </div>

  <div id="saved-screen">
    <div class="saved-header">
      <div class="saved-title">📚 My Saved Playlists</div>
      <div class="saved-sub">Your feel-good collection — pick up where you left off.</div>
    </div>
    <div class="saved-grid" id="saved-grid"></div>
    <div class="saved-back"><button class="btn btn-ghost" onclick="hideSaved()">← Back</button></div>
  </div>
</div>
<div id="toast"></div>

<script>
// ── QUESTIONS ──
const QUESTIONS = [
  { id:"mood", label:"Right now…", text:"How are you feeling and what kind of boost do you need?", multi:false,
    options:[
      {emoji:"😔",label:"Low & need lifting",sub:"Pick me up, I'm in a funk"},
      {emoji:"😤",label:"Stressed & overwhelmed",sub:"Help me breathe and decompress"},
      {emoji:"🥱",label:"Bored & uninspired",sub:"Spark some excitement & wonder"},
      {emoji:"😊",label:"Good & want more",sub:"I'm doing well, let's make it great"},
    ]},
  { id:"music", label:"Sound check", text:"What kind of music makes your whole body feel alive?", multi:false,
    options:[
      {emoji:"🎸",label:"Upbeat & energetic",sub:"Pop, rock, dance, hype anthems"},
      {emoji:"🎷",label:"Smooth & soulful",sub:"R&B, jazz, lo-fi, chill vibes"},
      {emoji:"🌿",label:"Calm & atmospheric",sub:"Indie, acoustic, ambient, nature sounds"},
      {emoji:"🎻",label:"Classical & cinematic",sub:"Orchestral, movie scores, epic sweeps"},
    ]},
  { id:"reading", label:"Word fuel", text:"What kind of written content speaks to your soul?", multi:false,
    options:[
      {emoji:"💡",label:"Inspiring stories & wins",sub:"People overcoming odds, triumph"},
      {emoji:"🔬",label:"Fascinating facts & science",sub:"Mind-blowing discoveries, wonder"},
      {emoji:"🌺",label:"Poetry & beautiful language",sub:"Lyrical, emotional, deeply human"},
      {emoji:"😂",label:"Funny & light-hearted",sub:"Humor, wit, things that make me laugh"},
    ]},
  { id:"visual", label:"Eye candy", text:"What kind of images or videos fill you with joy?", multi:false,
    options:[
      {emoji:"🐾",label:"Animals & nature",sub:"Cute creatures, breathtaking landscapes"},
      {emoji:"🎨",label:"Art & beautiful design",sub:"Creative works, stunning visuals"},
      {emoji:"🏆",label:"Awe-inspiring achievements",sub:"Sports moments, acts of skill"},
      {emoji:"👶",label:"Heartwarming human moments",sub:"Kids, reunions, acts of kindness"},
    ]},
  { id:"activity", label:"Your jam", text:"What activities light you up when you actually do them?", multi:true,
    options:[
      {emoji:"🧘",label:"Moving my body",sub:"Yoga, dance, walks, stretching"},
      {emoji:"✍️",label:"Creating something",sub:"Writing, drawing, making things"},
      {emoji:"🍳",label:"Cooking or nurturing",sub:"Food, self-care, tending to things"},
      {emoji:"🌍",label:"Learning & exploring",sub:"New ideas, cultures, rabbit holes"},
    ]},
  { id:"recovery", label:"Your journey", text:"Which recovery & mental health themes feel most meaningful to you right now?", multi:true,
    options:[
      {emoji:"💪",label:"Strength & resilience",sub:"Stories of overcoming, not giving up"},
      {emoji:"🕊️",label:"Peace & acceptance",sub:"Letting go, finding calm in the chaos"},
      {emoji:"🤝",label:"Community & belonging",sub:"You're not alone — connection heals"},
      {emoji:"🌱",label:"Growth & becoming",sub:"Progress over perfection, one day at a time"},
    ]},
  { id:"depth", label:"Depth dial", text:"Right now, what's your vibe for content depth?", multi:false,
    options:[
      {emoji:"⚡",label:"Quick hits & instant joy",sub:"Short, sweet, immediately uplifting"},
      {emoji:"🌊",label:"Deep & immersive",sub:"I want to really sink in and feel it"},
      {emoji:"🎲",label:"Surprise me!",sub:"Mix it all up — I love variety"},
    ]},
];

// ── CONTENT LIBRARY ──
const SONGS = {
  "Upbeat & energetic":[
    {emoji:"🎵",type:"song",title:"Happy – Pharrell Williams",desc:"Pure, infectious joy bottled into four minutes. It's literally impossible not to feel your mood lift when those horns kick in. Play it loud and let it do its thing.",url:"https://www.youtube.com/watch?v=y6Sxv-sUYtM",link:"Open on YouTube"},
    {emoji:"🎵",type:"song",title:"Can't Stop the Feeling – Justin Timberlake",desc:"Written for the Trolls movie, this song is a certified mood elevator. The groove is irresistible and the message is simple: just dance, just feel it.",url:"https://www.youtube.com/watch?v=ru0K8uYEZWw",link:"Open on YouTube"},
    {emoji:"🎵",type:"song",title:"Good as Hell – Lizzo",desc:"Lizzo's anthem of self-love and resilience hits different every single time. It's the musical equivalent of a best friend hyping you up in the mirror.",url:"https://www.youtube.com/watch?v=SmbmeOgWsqE",link:"Open on YouTube"},
  ],

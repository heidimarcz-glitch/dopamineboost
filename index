  const interval=setInterval(()=>{msgIdx=(msgIdx+1)%LOADING_MSGS.length;msgEl.textContent=LOADING_MSGS[msgIdx];},900);
  setTimeout(()=>{
    clearInterval(interval);
    const data=buildPlaylistFromAnswers(answers);
    showResults(data,false);
  },3200);
}

// ── SHOW RESULTS ──
const BADGE_MAP={song:"badge-song",read:"badge-read",video:"badge-video",activity:"badge-activity",quote:"badge-quote",podcast:"badge-podcast",fact:"badge-fact"};
const TYPE_LABEL={song:"🎵 Song",read:"📖 Read",video:"▶️ Video",activity:"🌀 Activity",quote:"💬 Quote",podcast:"🎙️ Podcast",fact:"🔬 Fact"};

function showResults(data,isSaved){
  currentPlaylistData=data;
  document.getElementById("loading-screen").style.display="none";
  document.getElementById("results-screen").style.display="block";
  document.getElementById("results-intro").textContent=data.intro||"Your feel-good playlist is ready.";
  const saveBtn=document.getElementById("save-btn");
  if(saveBtn){saveBtn.disabled=!!isSaved;saveBtn.textContent=isSaved?"✅ Already Saved":"💾 Save This Playlist";}
  const titleEl=document.querySelector(".results-title");
  if(!document.querySelector(".mood-pill")){
    const pill=document.createElement("div");pill.className="mood-pill";
    titleEl.parentNode.insertBefore(pill,titleEl);
  }
  document.querySelector(".mood-pill").textContent=data.moodLabel||"Your Vibe";
  const recCount=(data.items||[]).filter(i=>i.isRecovery).length;
  if(recCount>0){
    const banner=document.getElementById("rec-banner");
    banner.style.display="flex";
    document.getElementById("rec-banner-text").textContent=recCount+" recovery-themed picks woven into your playlist";
  }
  const grid=document.getElementById("playlist-grid");
  grid.innerHTML="";
  (data.items||[]).forEach((item,i)=>{
    const typeClass=BADGE_MAP[item.type]||"badge-fact";
    const typeLabel=TYPE_LABEL[item.type]||item.type;
    const url=item.url&&item.url.startsWith("http")?item.url:"https://www.google.com/search?q="+encodeURIComponent(item.title);
    const card=document.createElement("div");
    card.className="playlist-item"+(item.isRecovery?" recovery-item":"");
    card.style.animationDelay=(i*0.065)+"s";
    card.innerHTML=
      '<div><div class="item-number">'+(i+1)+'</div></div>'+
      '<div class="item-body">'+
        (item.isRecovery?'<div class="recovery-tag">💚 Recovery Pick</div>':'')+
        '<div class="item-type-badge '+typeClass+'">'+typeLabel+'</div>'+
        '<div class="item-title">'+item.title+'</div>'+
        '<div class="item-desc">'+item.desc+'</div>'+
        '<a class="item-link" href="'+url+'" target="_blank" rel="noopener">'+(item.link||"Open →")+' ↗</a>'+
      '</div>'+
      '<div class="item-emoji">'+item.emoji+'</div>';
    grid.appendChild(card);
  });
  window.scrollTo({top:0,behavior:"smooth"});
}

// ── SAVE / LOAD via localStorage ──
function savePlaylist(){
  if(!currentPlaylistData)return;
  const btn=document.getElementById("save-btn");
  btn.disabled=true;
  const key="ssk_playlist_"+Date.now();
  const payload={
    key,
    savedAt:new Date().toISOString(),
    moodLabel:currentPlaylistData.moodLabel,
    intro:currentPlaylistData.intro,
    items:currentPlaylistData.items,
    recoveryCount:(currentPlaylistData.items||[]).filter(i=>i.isRecovery).length
  };
  try{
    localStorage.setItem(key,JSON.stringify(payload));
    btn.textContent="✅ Saved!";
    showToast("Playlist saved to your collection 💜");
    refreshSavedButton();
  }catch(e){
    btn.disabled=false;
    showToast("Couldn't save — please try again");
  }
}

function getSavedPlaylists(){
  const playlists=[];
  for(let i=0;i<localStorage.length;i++){
    const k=localStorage.key(i);
    if(k&&k.startsWith("ssk_playlist_")){
      try{playlists.push(JSON.parse(localStorage.getItem(k)));}catch(e){}
    }
  }
  return playlists.sort((a,b)=>new Date(b.savedAt)-new Date(a.savedAt));
}

function refreshSavedButton(){
  const playlists=getSavedPlaylists();
  const wrap=document.getElementById("saved-btn-wrap");
  if(wrap)wrap.style.display=playlists.length>0?"":"none";
}

function showSaved(){
  document.getElementById("quiz-screen").style.display="none";
  document.getElementById("results-screen").style.display="none";
  document.getElementById("loading-screen").style.display="none";
  document.getElementById("saved-screen").style.display="block";
  const grid=document.getElementById("saved-grid");
  const playlists=getSavedPlaylists();
  if(playlists.length===0){
    grid.innerHTML='<div class="saved-empty"><div class="saved-empty-icon">🎵</div><div style="font-weight:700;color:var(--ink);margin-bottom:8px">No saved playlists yet</div><div>Generate a playlist and hit Save to keep it here.</div></div>';
    return;
  }
  grid.innerHTML="";
  playlists.forEach((p,i)=>{
    const date=new Date(p.savedAt);
    const dateStr=date.toLocaleDateString("en-US",{month:"short",day:"numeric",year:"numeric"});
    const timeStr=date.toLocaleTimeString("en-US",{hour:"numeric",minute:"2-digit"});
    const recText=p.recoveryCount>0?" · 💚 "+p.recoveryCount+" recovery picks":"";
    const card=document.createElement("div");
    card.className="saved-card";
    card.style.animationDelay=(i*0.07)+"s";
    card.innerHTML=
      '<div class="saved-card-icon">🌟</div>'+
      '<div class="saved-card-body">'+
        '<div class="saved-card-label">Saved · '+dateStr+' at '+timeStr+'</div>'+
        '<div class="saved-card-title">'+(p.moodLabel||"My Playlist")+'</div>'+
        '<div class="saved-card-meta">12 items'+recText+'</div>'+
      '</div>'+
      '<div class="saved-card-actions">'+
        '<button class="btn-xs btn-xs-primary" onclick=\'viewSaved('+JSON.stringify(JSON.stringify(p))+')\'>View</button>'+
        '<button class="btn-xs btn-xs-danger" onclick=\'deleteSaved('+JSON.stringify(p.key)+',this)\'>Delete</button>'+
      '</div>';
    grid.appendChild(card);
  });
}

function hideSaved(){
  document.getElementById("saved-screen").style.display="none";
  document.getElementById("quiz-screen").style.display="";
  render();
}

function viewSaved(jsonStr){
  const p=JSON.parse(jsonStr);
  document.getElementById("saved-screen").style.display="none";
  showResults(p,true);
}

function deleteSaved(key,btn){
  if(!confirm("Remove this playlist from your saved collection?"))return;
  localStorage.removeItem(key);
  const card=btn.closest(".saved-card");
  card.style.transition="opacity .3s,transform .3s";
  card.style.opacity="0";card.style.transform="scale(0.95)";
  setTimeout(()=>{card.remove();showSaved();refreshSavedButton();},300);
  showToast("Playlist removed");
}

function showToast(msg){
  const t=document.getElementById("toast");
  t.textContent=msg;t.classList.add("show");
  setTimeout(()=>t.classList.remove("show"),3000);
}

render();
refreshSavedButton();
</script>
</body>
</html>

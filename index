// ── PLAYLIST BUILDER ──
function buildPlaylistFromAnswers(ans) {
  const items = [];
  const used = new Set();

  function pick(arr) {
    const available = arr.filter((_,i) => !used.has(arr[i].title));
    if (!available.length) return arr[Math.floor(Math.random()*arr.length)];
    const item = available[Math.floor(Math.random()*available.length)];
    used.add(item.title);
    return item;
  }

  // 2 songs based on music taste
  const songPool = SONGS[ans.music] || SONGS["Upbeat & energetic"];
  items.push({...pick(songPool), isRecovery:false});
  items.push({...pick(songPool), isRecovery:false});

  // 2 videos based on visual preference
  const videoPool = VIDEOS[ans.visual] || VIDEOS["Heartwarming human moments"];
  items.push({...pick(videoPool), isRecovery:false});

  // 2 reads based on reading preference
  const readPool = READS[ans.reading] || READS["Inspiring stories & wins"];
  items.push({...pick(readPool), isRecovery:false});
  items.push({...pick(readPool), isRecovery:false});

  // 2 general quotes
  items.push({...pick(QUOTES_GENERAL), isRecovery:false});
  items.push({...pick(QUOTES_GENERAL), isRecovery:false});

  // 1 activity based on activity preference
  const actArr = (ans.activity||[]);
  const actKey = actArr.length ? actArr[Math.floor(Math.random()*actArr.length)] : "Moving my body";
  const actPool = ACTIVITIES[actKey] || ACTIVITIES["Moving my body"];
  items.push({...pick(actPool), isRecovery:false});

  // 1 fact
  items.push({...pick(FACTS), isRecovery:false});

  // 3 recovery items based on recovery themes chosen
  const recovThemes = Array.isArray(ans.recovery) && ans.recovery.length ? ans.recovery : ["Growth & becoming"];
  const recovPicks = [];
  for (let t of recovThemes) {
    if (RECOVERY_ITEMS[t]) recovPicks.push(...RECOVERY_ITEMS[t]);
  }
  // pick 3 unique recovery items
  const usedRec = new Set();
  let recAdded = 0;
  while (recAdded < 3 && recovPicks.length) {
    const idx = Math.floor(Math.random()*recovPicks.length);
    const item = recovPicks[idx];
    if (!usedRec.has(item.title)) {
      usedRec.add(item.title);
      items.push({...item, isRecovery:true});
      recAdded++;
    }
    recovPicks.splice(idx,1);
    if (!recovPicks.length) break;
  }
  // fallback if not enough
  if (recAdded < 3) {
    const fallback = RECOVERY_ITEMS["Growth & becoming"].filter(i=>!usedRec.has(i.title));
    fallback.slice(0,3-recAdded).forEach(i=>items.push({...i,isRecovery:true}));
  }

  // shuffle non-recovery and weave recovery items in at positions 4, 8, 12
  const nonRec = items.filter(i=>!i.isRecovery);
  const rec = items.filter(i=>i.isRecovery);
  const final = [];
  let ni=0, ri=0;
  for (let pos=0; pos<12; pos++) {
    if ((pos===3||pos===7||pos===11) && ri<rec.length) final.push(rec[ri++]);
    else if (ni<nonRec.length) final.push(nonRec[ni++]);
    else if (ri<rec.length) final.push(rec[ri++]);
  }

  return {
    moodLabel: MOOD_LABELS[ans.mood] || "Your Vibe",
    intro: INTROS[ans.mood] || "This playlist was made just for you.",
    items: final.slice(0,12),
  };
}


let current=0, answers={}, currentPlaylistData=null;

function render() {
  const q=QUESTIONS[current], total=QUESTIONS.length;
  const pct=Math.round((current/total)*100);
  document.getElementById("progress-fill").style.width=pct+"%";
  document.getElementById("step-label").textContent="Step "+(current+1)+" of "+total;
  document.getElementById("pct-label").textContent=pct+"%";
  const sel=answers[q.id]||(q.multi?[]:"");
  const card=document.getElementById("question-card");
  card.innerHTML=
    '<div class="q-label">'+q.label+'</div>'+
    '<div class="q-text">'+q.text+'</div>'+
    (q.multi?'<div class="multi-hint">✔ Choose all that apply</div>':'')+
    '<div class="options" id="options"></div>'+
    '<div class="nav-row">'+
      (current>0?'<button class="btn btn-ghost" onclick="back()">← Back</button>':'<div></div>')+
      '<button class="btn btn-primary" id="next-btn" onclick="next()" disabled>'+
        (current===total-1?'Build My Playlist ✨':'Next →')+
      '</button></div>';
  card.style.animation="none"; void card.offsetWidth;
  card.style.animation="slideUp 0.42s cubic-bezier(.4,0,.2,1) both";
  const optDiv=document.getElementById("options");
  q.options.forEach(opt=>{
    const isSel=q.multi?(sel||[]).includes(opt.label):sel===opt.label;
    const btn=document.createElement("button");
    btn.className="option-btn"+(isSel?" selected":"");
    btn.innerHTML='<span class="option-emoji">'+opt.emoji+'</span>'+
      '<span class="option-text"><span>'+opt.label+'</span><div class="option-sub">'+opt.sub+'</div></span>';
    btn.onclick=()=>pick(opt.label,q.multi);
    optDiv.appendChild(btn);
  });
  checkNext();
}

function pick(label,multi){
  const q=QUESTIONS[current];
  if(multi){
    if(!answers[q.id])answers[q.id]=[];
    const idx=answers[q.id].indexOf(label);
    if(idx===-1)answers[q.id].push(label); else answers[q.id].splice(idx,1);
  } else { answers[q.id]=label; }
  render();
}
function checkNext(){
  const q=QUESTIONS[current],sel=answers[q.id];
  document.getElementById("next-btn").disabled=q.multi?!(sel&&sel.length>0):!sel;
}
function next(){if(current<QUESTIONS.length-1){current++;render();}else buildPlaylist();}
function back(){if(current>0){current--;render();}}
function restart(){
  current=0;answers={};
  document.getElementById("results-screen").style.display="none";
  document.getElementById("quiz-screen").style.display="";
  const mp=document.querySelector(".mood-pill");if(mp)mp.remove();
  render();
}

